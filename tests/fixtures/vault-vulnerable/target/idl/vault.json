{
  "version": "0.30.0",
  "name": "vault",
  "instructions": [
    {
      "name": "deposit",
      "accounts": [
        { "name": "user",      "writable": true,  "signer": false },
        { "name": "authority", "writable": false, "signer": false },
        { "name": "vault",     "writable": true,  "signer": false }
      ],
      "args": [
        { "name": "amount", "type": "u64" }
      ],
      "discriminator": [1, 2, 3, 4, 5, 6, 7, 8]
    },
    {
      "name": "withdraw",
      "accounts": [
        { "name": "authority",   "writable": false, "signer": false },
        { "name": "vault",       "writable": true,  "signer": false },
        { "name": "destination", "writable": false, "signer": false }
      ],
      "args": [
        { "name": "amount", "type": "u64" }
      ],
      "discriminator": [9, 10, 11, 12, 13, 14, 15, 16]
    }
  ],
  "accounts": [
    { "name": "Vault", "discriminator": [100, 101, 102, 103, 104, 105, 106, 107] }
  ],
  "types": [
    {
      "name": "VaultState",
      "kind": "struct",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "authority", "type": "pubkey" },
          { "name": "total",     "type": "u64" }
        ]
      }
    }
  ],
  "events": [],
  "errors": [
    { "code": 6000, "name": "InsufficientFunds", "msg": "not enough lamports" }
  ]
}
