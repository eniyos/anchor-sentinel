{
  "version": "0.30.0",
  "name": "vault",
  "instructions": [
    {
      "name": "initialize",
      "accounts": [
        { "name": "payer",          "writable": true,  "signer": true },
        { "name": "vault",          "writable": true,  "signer": false },
        { "name": "system_program", "writable": false, "signer": false }
      ],
      "args": [],
      "discriminator": [1, 2, 3, 4, 5, 6, 7, 8]
    },
    {
      "name": "deposit",
      "accounts": [
        { "name": "user",      "writable": false, "signer": true },
        { "name": "vault",     "writable": true,  "signer": false },
        { "name": "authority", "writable": false, "signer": true }
      ],
      "args": [
        { "name": "amount", "type": "u64" }
      ],
      "discriminator": [2, 3, 4, 5, 6, 7, 8, 9]
    },
    {
      "name": "withdraw",
      "accounts": [
        { "name": "authority",   "writable": false, "signer": true },
        { "name": "vault",       "writable": true,  "signer": true },
        { "name": "destination", "writable": true,  "signer": false }
      ],
      "args": [
        { "name": "amount", "type": "u64" }
      ],
      "discriminator": [3, 4, 5, 6, 7, 8, 9, 10]
    }
  ],
  "accounts": [
    { "name": "Vault", "discriminator": [100, 101, 102, 103, 104, 105, 106, 107] }
  ],
  "types": [
    {
      "name": "Vault",
      "kind": "struct",
      "type": {
        "kind": "struct",
        "fields": [
          { "name": "authority", "type": "pubkey" },
          { "name": "total",     "type": "u64" }
        ]
      }
    }
  ],
  "events": [],
  "errors": [
    { "code": 6000, "name": "Overflow", "msg": "arithmetic overflow" }
  ]
}
